RewriteEngine On

# 301: always use canonical host+scheme
# Canonical: https://мемория.бел/ (punycode: xn--e1agkbkm0i.xn--90ais)
RewriteCond %{HTTP_HOST} !^xn--e1agkbkm0i\.xn--90ais$ [NC]
RewriteRule ^ https://xn--e1agkbkm0i.xn--90ais%{REQUEST_URI} [R=301,L]

# 301: force HTTPS on canonical host
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://xn--e1agkbkm0i.xn--90ais%{REQUEST_URI} [R=301,L]
